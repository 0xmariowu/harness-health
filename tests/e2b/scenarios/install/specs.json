{
  "scenarios": [
    {
      "id": "S01-install-node20-ubuntu22",
      "layer": "install",
      "scenario_type": "install",
      "node_version": "20",
      "description": "npm install -g agentlint on Ubuntu 22.04 + Node 20",
      "timeout": 300,
      "use_synthetic": false,
      "expected": {
        "version_pattern": "^\\d+\\.\\d+\\.\\d+$",
        "help_contains": [
          "check",
          "fix",
          "setup"
        ],
        "check_exits_nonzero_on_empty": false
      }
    },
    {
