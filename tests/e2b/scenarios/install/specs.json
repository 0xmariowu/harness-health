      "description": "agentlint setup --lang ts creates all expected files",
      "timeout": 300,
      "use_synthetic": false,
      "expected": {
        "files_exist": [
          ".github/workflows",
          "CLAUDE.md",
          "SECURITY.md"
        ],
        "claude_md_has_no_placeholder": true
      }
