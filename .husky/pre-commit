#!/usr/bin/env bash
unset GIT_DIR GIT_WORK_TREE GIT_INDEX_FILE

# Author identity check â€” whitelist only
AUTHOR_EMAIL=$(git config user.email)
AUTHOR_NAME=$(git config user.name)
if [ "$AUTHOR_EMAIL" != "130952152+0xmariowu@users.noreply.github.com" ]; then
  echo "error: git email '$AUTHOR_EMAIL' is not the noreply address"
  echo "fix: git config user.email '130952152+0xmariowu@users.noreply.github.com'"
  exit 1
fi
if [ "$AUTHOR_NAME" != "0xmariowu" ]; then
  echo "error: git name '$AUTHOR_NAME' is not the public pseudonym"
  echo "fix: git config user.name '0xmariowu'"
  exit 1
fi

SCAN_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -v -E '(\.gitleaks\.toml$|\.husky/|^CLAUDE\.md$|\.github/workflows/)' || true)

# Private-pattern scan â€” patterns live outside this public repo.
# Create ~/.agentlint-private-patterns (one regex per line, blank/# ignored) to enable.
# Typical contents: internal codenames, private hostnames, or any string you never want to ship.
PRIVATE_PATTERNS_FILE="${AGENTLINT_PRIVATE_PATTERNS_FILE:-${HOME}/.agentlint-private-patterns}"
if [ -n "$SCAN_FILES" ] && [ -f "$PRIVATE_PATTERNS_FILE" ]; then
  PRIVATE_REGEX=$(grep -vE '^(#|\s*$)' "$PRIVATE_PATTERNS_FILE" | paste -sd '|' -)
  if [ -n "$PRIVATE_REGEX" ]; then
    PRIV_MATCHES=$(echo "$SCAN_FILES" | while IFS= read -r f; do grep -nEH "$PRIVATE_REGEX" "$f" 2>/dev/null; done || true)
    if [ -n "$PRIV_MATCHES" ]; then
      echo "error: private patterns (${PRIVATE_PATTERNS_FILE}) matched in staged files:"
      echo "$PRIV_MATCHES"
      exit 1
    fi
  fi
fi

# Generic PII scan â€” personal paths (applies to everyone, no repo-specific knowledge)
if [ -n "$SCAN_FILES" ]; then
  PII_MATCHES=$(echo "$SCAN_FILES" | while IFS= read -r f; do grep -nEH '/Users/[a-zA-Z]|/home/[a-z]' "$f" 2>/dev/null; done | grep -v '/Users/xxx\|/home/xxx\|/home/testuser' || true)
  if [ -n "$PII_MATCHES" ]; then
    echo "error: personal paths in staged files:"
    echo "$PII_MATCHES"
    exit 1
  fi
fi

# Secret detection
SECRET_PATTERNS='(API_KEY|SECRET_KEY|PRIVATE_KEY|AUTH_TOKEN|PASSWORD)\s*=\s*["\x27][^\s"'\'']+|sk-[a-zA-Z0-9]{20,}|ghp_[a-zA-Z0-9]{36}|AIzaSy[a-zA-Z0-9_-]{33}|sk-ant-[a-zA-Z0-9_-]{40,}|sk-or-[a-zA-Z0-9_-]{20,}|github_pat_[a-zA-Z0-9_]{22,}'
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -v -E '(\.example$|\.test\.js$|tests/fixtures/|\.md$)' || true)
if [ -n "$STAGED_FILES" ]; then
  MATCHES=$(echo "$STAGED_FILES" | while IFS= read -r f; do grep -nEH "$SECRET_PATTERNS" "$f" 2>/dev/null; done || true)
  if [ -n "$MATCHES" ]; then
    echo "error: potential secrets detected in staged files:"
    echo "$MATCHES"
    exit 1
  fi
fi

# ShellCheck on staged shell scripts
SH_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.sh$' || true)
if [ -n "$SH_FILES" ] && command -v shellcheck >/dev/null 2>&1; then
  echo "$SH_FILES" | xargs shellcheck 2>/dev/null || true
fi
