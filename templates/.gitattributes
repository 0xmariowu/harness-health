# Normalize line endings across platforms.
# Without this, Windows contributors produce CRLF diffs that blow up reviews
# and break shell scripts that parse line-by-line.
* text=auto eol=lf

# Binary files — never normalize
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary

# Shell scripts — always LF, even on Windows checkouts
*.sh text eol=lf
*.bash text eol=lf

# GitHub Linguist overrides: hide generated/vendored files from repo stats
*.lock linguist-generated=true
package-lock.json linguist-generated=true
