# AgentLint Configuration
# Copy this file to .env and fill in real values. Never commit .env.

# Database
# Using SQLite (default) - no DATABASE_URL needed

# AI Assistants
CLAUDE_USE_GLOBAL_AUTH=true

# Codex Authentication
CODEX_ID_TOKEN=your_codex_id_token_here
CODEX_ACCESS_TOKEN=your_codex_access_token_here
CODEX_REFRESH_TOKEN=your_codex_refresh_token_here
CODEX_ACCOUNT_ID=your_codex_account_uuid_here

# Default AI Assistant
DEFAULT_AI_ASSISTANT=claude

# GitHub
GH_TOKEN=github_pat_your_token_here
GITHUB_TOKEN=github_pat_your_token_here
WEBHOOK_SECRET=your_webhook_secret_hex_here
GITHUB_ALLOWED_USERS=your_github_username

# Server
PORT=3000

# Concurrency
MAX_CONCURRENT_CONVERSATIONS=10
